---
import trackerData from '../data/tracker.json';

const habits = trackerData.habits;
const entries = trackerData.entries as Record<string, boolean[]>;

// Build last 90 days
const today = new Date();
const days: string[] = [];
for (let i = 89; i >= 0; i--) {
  const d = new Date(today);
  d.setDate(d.getDate() - i);
  days.push(d.toISOString().split('T')[0]);
}

// Calculate streaks and completion
function getStreak(habitIndex: number): number {
  let streak = 0;
  const sortedDays = [...days].reverse();
  for (const day of sortedDays) {
    const entry = entries[day];
    if (entry && entry[habitIndex]) {
      streak++;
    } else {
      break;
    }
  }
  return streak;
}

function getCompletionPct(habitIndex: number): number {
  const filled = days.filter(d => entries[d]?.[habitIndex]).length;
  return Math.round((filled / days.length) * 100);
}

function getCellColor(day: string): string {
  const entry = entries[day];
  if (!entry) return 'var(--color-surface)';
  const count = entry.filter(Boolean).length;
  if (count === 0) return 'var(--color-surface)';
  if (count === 1) return '#0e4429';
  if (count === 2) return '#1a7f37';
  return '#39d353';
}

function getCellOpacity(day: string): string {
  const entry = entries[day];
  if (!entry) return '0.3';
  return '1';
}

// Group into weeks (columns)
const weeks: string[][] = [];
let currentWeek: string[] = [];

// Pad the start so the first day falls on the correct day-of-week
const firstDay = new Date(days[0]);
const firstDow = firstDay.getDay(); // 0=Sun
for (let i = 0; i < firstDow; i++) {
  currentWeek.push('');
}

for (const day of days) {
  currentWeek.push(day);
  if (currentWeek.length === 7) {
    weeks.push(currentWeek);
    currentWeek = [];
  }
}
if (currentWeek.length > 0) {
  while (currentWeek.length < 7) currentWeek.push('');
  weeks.push(currentWeek);
}

const dayLabels = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
---

<div>
  <div class="flex items-center gap-2 mb-6">
    <div class="flex gap-1.5 items-center text-xs" style="color: var(--color-text-secondary);">
      <span>Less</span>
      {[0, 1, 2, 3].map(n => (
        <div class="w-3 h-3 rounded-sm" style={`background-color: ${n === 0 ? 'var(--color-surface)' : n === 1 ? '#0e4429' : n === 2 ? '#1a7f37' : '#39d353'}; border: 1px solid var(--color-border);`}></div>
      ))}
      <span>More</span>
    </div>
  </div>

  <div class="overflow-x-auto">
    <div class="flex gap-1" style="min-width: fit-content;">
      <!-- Day labels -->
      <div class="flex flex-col gap-1 mr-1">
        <div class="w-8 h-3"></div>
        {dayLabels.map((label, i) => (
          <div class="w-8 h-3 text-xs flex items-center" style="color: var(--color-text-secondary);">
            {i % 2 === 1 ? label.slice(0, 1) : ''}
          </div>
        ))}
      </div>
      <!-- Grid columns -->
      {weeks.map((week, wi) => (
        <div class="flex flex-col gap-1">
          <div class="h-3 text-xs" style="color: var(--color-text-secondary); font-size: 10px;">
            {wi % 4 === 0 && week[0] ? new Date(week.find(d => d) || '').toLocaleDateString('en-US', { month: 'short' }) : ''}
          </div>
          {week.map((day, di) => (
            <div
              class="w-3 h-3 rounded-sm"
              style={`background-color: ${day ? getCellColor(day) : 'transparent'}; border: ${day ? '1px solid var(--color-border)' : 'none'};`}
              title={day ? `${day}: ${entries[day] ? habits.filter((_, i) => entries[day][i]).join(', ') || 'none' : 'no data'}` : ''}
            ></div>
          ))}
        </div>
      ))}
    </div>
  </div>

  <!-- Stats per habit -->
  <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-4">
    {habits.map((habit, i) => (
      <div class="rounded-lg border p-4" style="background-color: var(--color-surface); border-color: var(--color-border);">
        <p class="text-xs font-mono mb-2" style="color: var(--color-accent);">{habit}</p>
        <div class="flex items-center gap-4">
          <div>
            <p class="text-2xl font-bold font-mono" style="color: var(--color-text-primary);">{getStreak(i)}</p>
            <p class="text-xs" style="color: var(--color-text-secondary);">day streak</p>
          </div>
          <div>
            <p class="text-2xl font-bold font-mono" style="color: var(--color-text-primary);">{getCompletionPct(i)}%</p>
            <p class="text-xs" style="color: var(--color-text-secondary);">90-day rate</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
