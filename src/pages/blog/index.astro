---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function readTime(body: string | undefined): string {
  if (!body) return '1 min read';
  const words = body.split(/\s+/).length;
  const minutes = Math.max(1, Math.round(words / 200));
  return `${minutes} min read`;
}

function postSlug(id: string): string {
  return id.replace(/\.(md|mdx)$/, '');
}
---

<BaseLayout title="Blog — Daniel William" description="Writing about AI engineering, systems, and the journey">
  <div class="max-w-2xl mx-auto px-6 py-16">
    <div class="mb-12">
      <h1 class="text-3xl font-bold mb-3" style="font-family: var(--font-family-mono); color: var(--color-text-primary);">Blog</h1>
      <p class="text-sm" style="color: var(--color-text-secondary);">
        Notes on AI engineering, systems, and building in public.
      </p>
    </div>
    <div class="space-y-8">
      {posts.map(post => (
        <article>
          <a href={`/blog/${postSlug(post.id)}`} class="group block">
            <time class="text-xs font-mono" style="color: var(--color-text-secondary);">
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              <span class="ml-3">{readTime(post.body)}</span>
            </time>
            <h2 class="text-lg font-semibold mt-1 mb-1 group-hover:underline" style="color: var(--color-text-primary);">{post.data.title}</h2>
            <p class="text-sm" style="color: var(--color-text-secondary);">{post.data.description}</p>
          </a>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
